#!/bin/sh
C1='\033[1;34m'
C2='\033[38;5;1m'
C3='\033[38;5;3m'
C4='\033[38;5;156m'
C5='\033[38;5;4m'
C6='\033[38;5;5m'
NC='\033[0m'

printf "${C1}┌───${NC}\n"
printf "${C2}│ ${C3}$USER${NC}${C4}@${NC}${C5}$HOSTNAME${NC}\n"
printf "${C1}│ $(uname -rs)${NC}\n"
printf "${C5}│ wm: dwm${NC}\n"
printf "${C3}│ term: st${NC}\n"
printf "${C2}│ shell: $SHELL${NC}\n"
printf "${C6}│ media: mpv${NC}\n"
printf "${C4}│ editor: $EDITOR${NC}\n"
printf "\n"
