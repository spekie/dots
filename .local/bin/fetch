#!/bin/sh
C1='\e[1;34m'
C2='\033[38;5;1m'
C3='\033[38;5;3m'
C4='\033[38;5;156m'
C5='\033[38;5;4m'
C6='\033[38;5;5m'
NC='\033[0m'

printf "${C1}       /\\         ┌───${NC}\n"
printf "${C1}      /  \\        │ Arch GNU/Linux${NC}\n"
printf "${C1}     /\\   \\ ${NC}      ${C5}│ wm: dwm${NC}\n"
printf "${C1}    /      \\ ${NC}     ${C3}│ term: st${NC}\n"
printf "${C1}   /   ,,   \\ ${NC}    ${C2}│ shell: bash${NC}\n"
printf "${C1}  /   |  |  -\\ ${NC}   ${C6}│ media: mpv${NC}\n"
printf "${C1} /_-''    ''-_\\ ${NC}  ${C4}│ editor: vim${NC}\n"
printf "\n"
