#!/bin/sh
# XDG Base Directory
mkdir -p $HOME/.local/share
mkdir -p $HOME/.local/state
mkdir -p $HOME/.local/bin
mkdir -p $HOME/.config
mkdir -p $HOME/.cache
chmod 700 $HOME/.local
chmod 700 $HOME/.local/*
chmod 700 $HOME/.config
chmod 700 $HOME/.cache
# XDG user directories
mkdir -p $HOME/dls
mkdir -p $HOME/docs
mkdir -p $HOME/mus
mkdir -p $HOME/pics
cp $HOME/dots/.config/user-dirs.dirs $XDG_CONFIG_HOME
xdg-user-dirs-update
