#!/bin/sh
printf "input video file path: "
read input_file

if [ ! -f "$input_file" ]; then
    echo "file '$input_file' does not exist."
    exit 1
fi

printf "cut the video from (1 second = 00:00:01): "
read start_time

printf "to (5 seconds = 00:00:05): "
read end_time

base_name=${input_file%.*}
extension=${input_file##*.}
output_file="${base_name}_cut.${extension}"

ffmpeg -i "$input_file" -ss "$start_time" -to "$end_time" -c copy "$output_file"

echo "cut output: $output_file"
